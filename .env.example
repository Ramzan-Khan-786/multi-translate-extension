# TextBridge environment template
# Copy this file to .env and fill your own values.

# Google OAuth (Chrome extension)
GOOGLE_OAUTH_CLIENT_ID=YOUR_EXTENSION_OAUTH_CLIENT_ID.apps.googleusercontent.com
GOOGLE_OAUTH_PROJECT_ID=YOUR_GOOGLE_CLOUD_PROJECT_ID
GOOGLE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
GOOGLE_TOKEN_URI=https://oauth2.googleapis.com/token
GOOGLE_AUTH_PROVIDER_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
GOOGLE_SHEETS_SCOPE=https://www.googleapis.com/auth/spreadsheets

# Google Sheets sync defaults
SHEETS_SPREADSHEET_ID=YOUR_SPREADSHEET_ID
SHEETS_HISTORY_SHEET_NAME=TextBridge History
SHEETS_QUICK_SHEET_NAME=TextBridge Quick
SHEETS_SYNC_ENABLED=false
SHEETS_LOCAL_HISTORY_MODE=hybrid

# Translation/TTS endpoints
GOOGLE_TRANSLATE_API_BASE=https://translate.googleapis.com
GOOGLE_TRANSLATE_WEB_BASE=https://translate.google.com
DICTIONARY_API_BASE=https://api.dictionaryapi.dev
GOOGLE_SHEETS_API_BASE=https://sheets.googleapis.com
