{
  "manifest_version": 3,
  "name": "TextBridge",
  "version": "3.3.1",
  "description": "Capture selected English text and show definition, native translation, and romanized transliteration.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "webNavigation",
    "tabs",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "tts",
    "identity"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://translate.googleapis.com/*",
    "https://api.dictionaryapi.dev/api/v2/entries/en/*",
    "https://translate.google.com/*",
    "https://sheets.googleapis.com/*"
  ],
  "oauth2": {
    "client_id": "REPLACE_WITH_EXTENSION_OAUTH_CLIENT_ID",
    "scopes": [
      "https://www.googleapis.com/auth/spreadsheets"
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "TextBridge"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "<all_urls>",
        "file:///*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "content.js",
        "styles.css",
        "assets/fonts/*.woff2"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "icons": {
    "128": "icons/icon.png"
  }
}
